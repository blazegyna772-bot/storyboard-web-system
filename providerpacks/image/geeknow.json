{
  "id": "geeknow",
  "name": "Geeknow 聚合生图",
  "description": "兼容 Gemini generateContent 与 OpenAI images/generations 的聚合站。",
  "baseUrls": [
    { "label": "副节点", "url": "https://api.geeknow.ai" },
    { "label": "主节点", "url": "https://geeknow.ai" }
  ],
  "defaultModel": "gemini-3.1-flash-image-preview",
  "fields": [
    { "key": "apiKey", "label": "API Key", "type": "password", "required": true },
    { "key": "baseUrl", "label": "线路", "type": "select", "source": "baseUrls", "required": true },
    { "key": "model", "label": "模型", "type": "select", "source": "models", "required": true },
    { "key": "aspectRatio", "label": "画幅", "type": "model-select", "source": "aspectRatios", "required": true },
    { "key": "imageSize", "label": "分辨率档位", "type": "model-select", "source": "imageSizes" },
    { "key": "size", "label": "输出尺寸", "type": "model-size", "source": "sizeMap" },
    { "key": "requestTimeout", "label": "请求超时秒数", "type": "number", "min": 30, "max": 900, "required": true },
    { "key": "downloadTimeout", "label": "下载超时秒数", "type": "number", "min": 30, "max": 900, "required": true }
  ],
  "models": [
    {
      "id": "gemini-3.1-flash-image-preview",
      "label": "Gemini 3.1 Flash Image",
      "protocol": "gemini-generate-content",
      "endpointTemplate": "{baseUrl}/v1beta/models/{model}:generateContent",
      "aspectRatios": ["1:1", "16:9", "9:16", "4:3", "3:4", "3:2", "2:3", "21:9"],
      "imageSizes": ["1K"],
      "defaultAspectRatio": "16:9",
      "defaultImageSize": "1K",
      "defaultSize": "1920x1080",
      "supportsReferenceImages": true,
      "supportsMultipleImages": false
    },
    {
      "id": "gemini-3-pro-image-preview",
      "label": "Gemini 3 Pro Image",
      "protocol": "gemini-generate-content",
      "endpointTemplate": "{baseUrl}/v1beta/models/{model}:generateContent",
      "aspectRatios": ["1:1", "16:9", "9:16", "4:3", "3:4", "3:2", "2:3", "21:9"],
      "imageSizes": ["1K", "2K"],
      "defaultAspectRatio": "16:9",
      "defaultImageSize": "2K",
      "defaultSize": "1920x1080",
      "supportsReferenceImages": true,
      "supportsMultipleImages": false
    },
    {
      "id": "gpt-image-2",
      "label": "GPT Image 2",
      "protocol": "openai-images",
      "endpointTemplate": "{baseUrl}/v1/images/generations",
      "aspectRatios": ["1:1", "4:3", "2:3", "3:2", "16:9", "9:16", "1:1(2K)", "4:3(2K)", "3:2(2K)", "2:3(2K)", "16:9(2K)", "9:16(2K)", "1:1(4K)", "4:3(4K)", "3:2(4K)", "2:3(4K)", "16:9(4K)", "9:16(4K)"],
      "imageSizes": [],
      "sizeMap": {
        "1:1": "1024x1024",
        "4:3": "1536x1152",
        "2:3": "1024x1536",
        "3:2": "1536x1024",
        "16:9": "1920x1080",
        "9:16": "1080x1920",
        "1:1(2K)": "2048x2048",
        "4:3(2K)": "2048x1536",
        "3:2(2K)": "2560x1712",
        "2:3(2K)": "1712x2560",
        "16:9(2K)": "2048x1152",
        "9:16(2K)": "1152x2048",
        "1:1(4K)": "2880x2880",
        "4:3(4K)": "3840x2880",
        "3:2(4K)": "3840x2560",
        "2:3(4K)": "2560x3840",
        "16:9(4K)": "3840x2160",
        "9:16(4K)": "2160x3840"
      },
      "defaultAspectRatio": "1:1",
      "defaultImageSize": "",
      "defaultSize": "1024x1024",
      "supportsReferenceImages": true,
      "supportsMultipleImages": true
    },
    {
      "id": "gpt-image-2-pro",
      "label": "GPT Image 2 Pro",
      "protocol": "openai-images",
      "endpointTemplate": "{baseUrl}/v1/images/generations",
      "aspectRatios": ["1:1", "4:3", "2:3", "3:2", "16:9", "9:16", "1:1(2K)", "4:3(2K)", "3:2(2K)", "2:3(2K)", "16:9(2K)", "9:16(2K)", "1:1(4K)", "4:3(4K)", "3:2(4K)", "2:3(4K)", "16:9(4K)", "9:16(4K)"],
      "imageSizes": [],
      "sizeMap": {
        "1:1": "1024x1024",
        "4:3": "1536x1152",
        "2:3": "1024x1536",
        "3:2": "1536x1024",
        "16:9": "1920x1080",
        "9:16": "1080x1920",
        "1:1(2K)": "2048x2048",
        "4:3(2K)": "2048x1536",
        "3:2(2K)": "2560x1712",
        "2:3(2K)": "1712x2560",
        "16:9(2K)": "2048x1152",
        "9:16(2K)": "1152x2048",
        "1:1(4K)": "2880x2880",
        "4:3(4K)": "3840x2880",
        "3:2(4K)": "3840x2560",
        "2:3(4K)": "2560x3840",
        "16:9(4K)": "3840x2160",
        "9:16(4K)": "2160x3840"
      },
      "defaultAspectRatio": "16:9(4K)",
      "defaultImageSize": "",
      "defaultSize": "3840x2160",
      "supportsReferenceImages": true,
      "supportsMultipleImages": true
    }
  ]
}
